# Copia este archivo a .env (o exporta las variables) y pon tu clave de DeepSeek.
# Si no, el verificador la lee automáticamente del .env.local de EdifcIA.
DEEPSEEK_API_KEY=sk-...

# Opcionales (tienen valores por defecto sensatos):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# EDIFICIA_DIR=/ruta/a/EdifcIA   # si moviste ese proyecto de lugar
